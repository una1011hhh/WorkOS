# WorkOS environment variables
# Copy this file to .env.local for local development.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Feishu integration (server-side only)
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Notes:
# - Leave Supabase values empty to keep WorkOS in localStorage-only mode.
# - FEISHU_APP_SECRET must never use NEXT_PUBLIC_ prefix.
# - Never commit .env.local.
